# Persona — who is the user?
# PERSONA_FILE points to a markdown file describing the user that gets injected
# into Squire's system prompt at startup. Copy prompts/persona.example.md to
# prompts/persona.local.md (gitignored), edit it, then point PERSONA_FILE there.
PERSONA_FILE=./prompts/persona.example.md
# USER_NAME is referenced in tool descriptions and prompts that address the user
# by name. Leave blank to use generic phrasing ("the user").
USER_NAME=

# Database
DATABASE_URL=postgresql://squire:squire_dev@localhost:5435/squire

# API Server
PORT=3000
NODE_ENV=development
# CORS_ORIGIN must be set to your frontend's URL in production (the server
# refuses to start if it's missing or set to localhost in production).
CORS_ORIGIN=http://localhost:3001

# API authentication. If set, every REST request and Socket.IO connection
# must present this key (header `x-api-key` / `Authorization: Bearer …` or
# Socket.IO `auth.token`). If unset, auth is DISABLED (dev mode only —
# the server refuses to start in production without a key).
# Generate one with: openssl rand -hex 32
# SQUIRE_API_KEY=

# Tools that can shell out, write files, or fetch arbitrary URLs are
# DANGEROUS in the presence of prompt injection. They are disabled by
# default. Only enable if you understand and accept the threat model
# (see SECURITY.md). When disabled, bash, claude_code, sandbox, and
# browser_* tools are not registered.
SQUIRE_ENABLE_DANGEROUS_TOOLS=false

# Embeddings
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSION=768
OLLAMA_URL=http://localhost:11434

# Alternative: mxbai-embed-large (1024 dimensions)
# EMBED_MODEL=mxbai-embed-large
# EMBED_DIMENSION=1024

# LLM Provider - Anthropic Claude (recommended for Squire Agent)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7

# Alternative: Groq with llama-3.3-70b
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=your_groq_api_key_here

# Alternative: xAI Grok
# LLM_PROVIDER=xai
# LLM_MODEL=grok-3-fast
# XAI_API_KEY=your_xai_api_key_here

# Alternative: Google Gemini
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro
# GEMINI_API_KEY=your_gemini_api_key_here

# Alternative: Ollama for local LLM
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2

# Enhanced Recall (memory retrieval pipeline)
# User-specific stopwords (comma-separated, e.g. your name)
# RECALL_USER_STOPWORDS=
# Cache TTL for IDF/graph indexes (ms, default 300000 = 5min)
# RECALL_CACHE_TTL_MS=300000
# LLM reranker (requires XAI_API_KEY)
# RECALL_RERANKER_ENABLED=true
# RECALL_RERANKER_PROVIDER=xai
# RECALL_RERANKER_MODEL=grok-4-1-fast-reasoning
# RECALL_RERANKER_POOL=15

# Feature Flags
# ENABLE_EMOTION_TAGGING=false

# AgentMail (optional — gives Squire its own email address for inbound/outbound)
# Sign up at https://agentmail.to to get a key + create an inbox.
# AGENTMAIL_API_KEY=
# AGENTMAIL_INBOX_ID=your-squire-inbox@agentmail.to
# AGENTMAIL_BASE_URL=https://api.agentmail.to/v0

# PDF form-fill helper script — defaults to ./scripts/pdf_form_fill.py.
# Override only if you've moved the script.
# PDF_FORM_FILL_SCRIPT=./scripts/pdf_form_fill.py

# Coding tools (claude_code, sandbox) — DANGEROUS, see Phase 3 docs.
# CODING_WORKING_DIR=/path/to/your/projects

# Telegram Bot Integration
# Get your bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated list of allowed Telegram user IDs
# Find your user ID by messaging @userinfobot on Telegram
# TELEGRAM_ALLOWED_USER_IDS=123456789
# Polling interval in ms (default 1000)
# TELEGRAM_POLLING_INTERVAL_MS=1000
