# =============================================================================
# Squire — Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in the values you need. .env is gitignored.
# At minimum, you need DATABASE_URL, an LLM provider key, and (if not using
# Ollama) an embedding provider key. Everything else is optional.
#
# In production (NODE_ENV=production), the server refuses to start without
# SQUIRE_API_KEY and a non-localhost CORS_ORIGIN.

# ----- Persona — who is the user? -------------------------------------------
# PERSONA_FILE points to a markdown file describing the user that gets
# injected into Squire's system prompt at startup. Copy
# prompts/persona.example.md to prompts/persona.local.md (gitignored), edit
# it to describe yourself, then point PERSONA_FILE at your copy.
PERSONA_FILE=./prompts/persona.example.md
# USER_NAME is referenced in tool descriptions and prompts that address the
# user by name. Leave blank to use generic phrasing ("the user").
USER_NAME=

# ----- Database -------------------------------------------------------------
DATABASE_URL=postgresql://squire:squire_dev@localhost:5435/squire

# ----- API Server -----------------------------------------------------------
PORT=3000
NODE_ENV=development
# CORS_ORIGIN must be set to your frontend's URL in production (the server
# refuses to start if it's missing or set to localhost in production).
CORS_ORIGIN=http://localhost:3001

# API authentication. If set, every REST request and Socket.IO connection
# must present this key (header `x-api-key` / `Authorization: Bearer …` or
# Socket.IO `auth.token`). If unset, auth is DISABLED (dev mode only — the
# server refuses to start in production without a key).
# Generate one with: openssl rand -hex 32
# SQUIRE_API_KEY=

# Tools that can shell out, write files, or fetch arbitrary URLs are
# DANGEROUS in the presence of prompt injection. They are disabled by
# default. Only enable if you understand and accept the threat model
# (see SECURITY.md). When disabled, bash, claude_code, sandbox, and
# browser_* tools are not registered.
SQUIRE_ENABLE_DANGEROUS_TOOLS=false

# ----- Rate limiting --------------------------------------------------------
# Sliding window applied to most REST endpoints. Defaults: 100 requests per
# 15 min per IP. Chat endpoints have their own (lower) cap because each
# request triggers an LLM call.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# CHAT_RATE_LIMIT_MAX=20

# ----- Embeddings -----------------------------------------------------------
# Default: Ollama (local, free, private — install nomic-embed-text via
# `ollama pull nomic-embed-text`).
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSION=768
OLLAMA_URL=http://localhost:11434

# Alternative: mxbai-embed-large (1024 dimensions, also via Ollama)
# EMBED_MODEL=mxbai-embed-large
# EMBED_DIMENSION=1024

# Alternative: OpenAI embeddings (requires API key, costs money)
# EMBED_PROVIDER=openai
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIMENSION=1536
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_URL=https://api.openai.com/v1
#
# OpenAI embedding models:
#   text-embedding-3-small  — 1536 dimensions (recommended, cheapest)
#   text-embedding-3-large  — 3072 dimensions (highest quality)

# ----- LLM Provider --------------------------------------------------------
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
# Per-request timeout for LLM calls (ms, default 60s).
# LLM_API_TIMEOUT_MS=60000

# Alternative: Groq with llama-3.3-70b
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=your_groq_api_key_here

# Alternative: xAI Grok
# LLM_PROVIDER=xai
# LLM_MODEL=grok-3-fast
# XAI_API_KEY=your_xai_api_key_here

# Alternative: Google Gemini
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro
# GEMINI_API_KEY=your_gemini_api_key_here

# Alternative: Ollama for local LLM
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2

# Override provider base URLs (e.g. for self-hosted proxies, OpenAI-compatible
# endpoints, or testing). Defaults point at each provider's public API.
# ANTHROPIC_URL=https://api.anthropic.com
# GROQ_URL=https://api.groq.com/openai/v1
# XAI_URL=https://api.x.ai/v1
# GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ----- Smart / fast tier routing --------------------------------------------
# Squire can route easy requests to a cheap "fast" model and reserve the
# "smart" model for harder ones. Defaults: smart=anthropic/claude-sonnet-4-6,
# fast=xai/grok-4-1-fast-reasoning. Set ROUTING_ENABLED=false to always use
# the LLM_PROVIDER/LLM_MODEL above.
# ROUTING_ENABLED=true
# ROUTING_DEFAULT_TIER=smart
# ROUTING_SMART_PROVIDER=anthropic
# ROUTING_SMART_MODEL=claude-sonnet-4-6
# ROUTING_FAST_PROVIDER=xai
# ROUTING_FAST_MODEL=grok-4-1-fast-reasoning

# ----- Search tuning --------------------------------------------------------
# Cosine-similarity floors for semantic search. Lower = more recall, higher =
# more precision. Tune per corpus.
# SEARCH_DOCUMENT_THRESHOLD=0.55
# SEARCH_CONTEXT_THRESHOLD=0.5
# SEARCH_NOTES_THRESHOLD=0.35

# ----- Enhanced Recall ------------------------------------------------------
# User-specific stopwords (comma-separated, e.g. your name + nicknames so
# they don't dominate similarity scores).
# RECALL_USER_STOPWORDS=
# Cache TTL for IDF/graph indexes (ms, default 300000 = 5min)
# RECALL_CACHE_TTL_MS=300000
# LLM reranker (requires XAI_API_KEY or ANTHROPIC_API_KEY). Adds latency
# and cost in exchange for better recall. Off by default for OSS.
# RECALL_RERANKER_ENABLED=false
# RECALL_RERANKER_PROVIDER=xai
# RECALL_RERANKER_MODEL=grok-4-1-fast-reasoning
# RECALL_RERANKER_POOL=15

# ----- Feature Flags (all default OFF for new installs) ---------------------
# Squire ships quiet — opt in to autonomous behavior explicitly. Each block
# below shows the enable flag plus the tunables you'd typically touch.

# Courier — proactive task scheduler (reminders, follow-ups).
# COURIER_ENABLED=true
# COURIER_INTERVAL_MS=1800000        # how often to wake (default 30 min)
# COURIER_QUIET_START=22             # don't deliver between this hour…
# COURIER_QUIET_END=7                # …and this hour (24h, local time)
# COURIER_RETRY_ATTEMPTS=3
# COURIER_RETRY_DELAY_MS=15000

# Commune — proactive outreach (Squire reaching out unprompted).
# COMMUNE_ENABLED=true
# COMMUNE_INTERVAL_MS=900000         # check cadence (default 15 min)
# COMMUNE_QUIET_START=22
# COMMUNE_QUIET_END=7
# COMMUNE_MAX_DAILY=5                # hard cap on outbound msgs/day
# COMMUNE_MIN_HOURS_BETWEEN=2        # gap between consecutive msgs
# COMMUNE_DEFAULT_CHANNEL=telegram   # telegram | push | email

# Goal worker — autonomous multi-turn execution of tracked goals.
# GOAL_WORKER_ENABLED=true
# GOAL_WORKER_INTERVAL_MS=3600000    # default hourly
# GOAL_WORKER_MAX_TURNS=15           # safety cap on tool-loop turns
# GOAL_WORKER_MAX_EXECUTION_MS=300000  # 5 min wall-clock per goal

# Expression evaluator — second-pass tone/safety filter on outbound text.
# Uses a local model by default to keep cost down. Provider/model can point
# at any configured LLM (anthropic, xai, groq, gemini, ollama).
# EXPRESSION_EVALUATOR_ENABLED=true
# EXPRESSION_EVALUATOR_PROVIDER=ollama
# EXPRESSION_EVALUATOR_MODEL=qwen2.5:3b
# EXPRESSION_EVALUATOR_BATCH_SIZE=10

# ----- Google Integrations (optional) ---------------------------------------
# Set these to enable Gmail + Calendar sync. If unset, Squire skips the
# Google integration cleanly at startup.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ----- AgentMail (optional) -------------------------------------------------
# Gives Squire its own email address for inbound + outbound mail.
# Sign up at https://agentmail.to to get a key + create an inbox.
# AGENTMAIL_API_KEY=
# AGENTMAIL_INBOX_ID=your-squire-inbox@agentmail.to
# AGENTMAIL_BASE_URL=https://api.agentmail.to/v0

# ----- Telegram Bot (optional) ----------------------------------------------
# Get your bot token from @BotFather on Telegram.
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated list of allowed Telegram user IDs (find yours with @userinfobot).
# TELEGRAM_ALLOWED_USER_IDS=123456789
# Polling interval in ms (default 1000)
# TELEGRAM_POLLING_INTERVAL_MS=1000

# ----- Web Push (optional, for PWA notifications) ---------------------------
# Generate keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# ----- Web Search (optional) ------------------------------------------------
# TAVILY_API_KEY=

# ----- TTS (optional) -------------------------------------------------------
# KOKORO_BASE_URL=http://localhost:8880

# ----- Coding tools (only used if SQUIRE_ENABLE_DANGEROUS_TOOLS=true) -------
# CODING_WORKING_DIR=/path/to/your/projects
# CODING_TIMEOUT_MS=30000            # per-command wall-clock cap
# CODING_MAX_OUTPUT_BYTES=1048576    # 1 MB cap on captured stdout/stderr
# PDF_FORM_FILL_SCRIPT=./scripts/pdf_form_fill.py
